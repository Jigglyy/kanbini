{
  "name": "@kanbini/desktop",
  "version": "0.3.1",
  "private": true,
  "license": "MIT",
  "description": "Kanbini desktop shell - Electron main + preload that hosts the renderer over typed IPC and exposes a loopback MCP control channel for AI tooling.",
  "author": "Kanbini",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/ensure-electron-abi.mjs && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "test:roundtrip": "electron-vite build && node scripts/run-round-trip.mjs",
    "test:launch": "node scripts/ensure-electron-abi.mjs && electron-vite build && node scripts/run-launch-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('out',{recursive:true,force:true})\"",
    "package:prepare": "node scripts/prepackage.mjs",
    "package:dir": "pnpm run package:prepare && electron-builder --dir",
    "package": "pnpm run package:prepare && electron-builder",
    "postpackage": "node scripts/check-payload.mjs",
    "check:payload": "node scripts/check-payload.mjs",
    "test:scripts": "node --test scripts/check-payload-core.test.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "build:notices": "node scripts/build-notices.mjs"
  },
  "dependencies": {
    "@kanbini/db": "workspace:*",
    "@kanbini/shared": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "undici": "^6.25.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.0",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^41.6.1",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "jimp": "^1.6.0",
    "png-to-ico": "^2.1.8",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.13"
  }
}
