{
  "name": "@kanbini/db",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:check": "node --disable-warning=ExperimentalWarning scripts/check-migration.mjs",
    "typecheck": "tsc --noEmit",
    "pretest": "node scripts/ensure-node-abi.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@kanbini/shared": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.10",
    "vitest": "^3.2.0"
  }
}
