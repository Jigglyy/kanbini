# Normalize all text files to LF in the repo, regardless of each
# contributor's core.autocrlf. Win + macOS project — keep history clean.
* text=auto eol=lf

# Source & config — always LF
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf
*.json    text eol=lf
*.jsonc   text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.html    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.toml    text eol=lf
*.sql     text eol=lf
*.sh      text eol=lf
*.env     text eol=lf
.gitignore      text eol=lf
.gitattributes  text eol=lf
LICENSE         text eol=lf

# Windows scripts must keep CRLF or cmd.exe mis-parses them
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# Binary — never touch line endings or diff as text
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.icns    binary
*.webp    binary
*.svg     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.otf     binary
*.eot     binary
*.pdf     binary
*.zip     binary
*.gz      binary
*.7z      binary
*.exe     binary
*.dll     binary
*.node    binary
*.sqlite  binary
*.db      binary

# Generated lockfiles: treated as text but collapse diffs in PR review
package-lock.json  -diff
pnpm-lock.yaml     -diff
